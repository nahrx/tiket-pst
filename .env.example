# Server
APP_PORT=8080
APP_ENV=production

# PostgreSQL
DB_HOST=db_host
DB_PORT=5432
DB_NAME=db_name
DB_USER=db_user
DB_PASSWORD=db_password
DB_SSLMODE=disable

# Atau gunakan DATABASE_URL (override semua field DB di atas)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/tiket_bps?sslmode=disable

# JWT
JWT_SECRET=contoh_jwt_secret
JWT_EXPIRY_HOURS=24

# Admin default (akan di-seed saat pertama run)
ADMIN_USERNAME=username
ADMIN_PASSWORD=password

# CORS - origins yang diizinkan (pisahkan dengan koma)
ALLOWED_ORIGINS=http://localhost:8080

# WA number PST
WA_NUMBER=628512312312

